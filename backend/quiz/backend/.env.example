## Quiz backend configuration
## Copy to ".env" and fill values.

# Preferred (matches MentorBot):
GEMINI_API_KEY=your_gemini_api_key_here

# Required: used to generate quiz questions via Groq
GROQ_API_KEY=your_groq_api_key_here

# Alternative (if you're using OpenRouter like the MentorBot flow)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=deepseek/deepseek-v3.2

# Optional: MongoDB connection string (defaults to localhost)
MONGO_URI=mongodb://localhost:27017

